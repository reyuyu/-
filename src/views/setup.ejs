<html lang="zh">
<head>
    <style>
        .form-input {
            box-sizing: border-box;
            font-size: 14px;
            font-variant: tabular-nums;
            line-height: 1.5;
            list-style: none;
            -webkit-font-feature-settings: "tnum";
            font-feature-settings: "tnum", "tnum";
            position: relative;
            display: inline-block;
            width: 100%;
            text-align: start;
            -webkit-font-feature-settings: "tnum";
            font-feature-settings: "tnum", "tnum";
            height: 32px;
            padding: 4px 11px;
            color: rgba(0, 0, 0, 0.36);
            background-color: #fff;
            background-image: none;
            border: 1px solid #d9d9d9;
            border-radius: 4px;
            -webkit-transition: all .3s;
            transition: all .3s;
            margin: 0 0 24px;
        }

        .form-input:hover {
            border-color: #40a9ff;
            border-right-width: 1px !important;
        }

        .login-form {
            width: 300px;
            position: absolute;
            top: 45%;
            left: 50%;
            -webkit-transform: translate(-50%, -50%);
            transform: translate(-50%, -50%);
        }

        .login-button {
            color: #fff;
            background-color: #1890ff;
            border-color: #1890ff;
            text-shadow: 0 -1px 0 rgba(0, 0, 0, .12);
            box-shadow: 0 2px 0 rgba(0, 0, 0, .045);
            line-height: 1.499;
            position: relative;
            display: inline-block;
            font-weight: 400;
            white-space: nowrap;
            text-align: center;
            background-image: none;
            cursor: pointer;
            -webkit-transition: all .3s cubic-bezier(.645, .045, .355, 1);
            transition: all .3s cubic-bezier(.645, .045, .355, 1);
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
            touch-action: manipulation;
            height: 32px;
            padding: 0 15px;
            font-size: 14px;
            border-radius: 4px;
            width: 100%;
        }

        button {
            /*消除button的默认样式*/
            /*这种写法是对所有的button标签同时生效*/
            margin: 0px;
            padding: 0px;
            /*自定义边框*/
            border: 0px;
            /*消除默认点击蓝色边框效果*/
            outline: none;
        }

        .login-button:hover {
            color: #fff;
            background-color: #40a9ff;
            border-color: #40a9ff;
            width: 100%;
        }

        .message {
            margin: -8px 0 16px;
            color: #d4380d;
            font-size: 13px;
            line-height: 1.5;
        }

        .cookie-login {
            margin-top: 20px;
            padding-top: 18px;
            border-top: 1px solid #d9d9d9;
        }

        .cookie-input {
            box-sizing: border-box;
            width: 100%;
            height: 92px;
            padding: 8px 11px;
            margin-bottom: 12px;
            border: 1px solid #d9d9d9;
            border-radius: 4px;
            resize: vertical;
            font-size: 13px;
            line-height: 1.5;
            outline: none;
        }

        .cookie-input:hover,
        .cookie-input:focus {
            border-color: #40a9ff;
        }

        .qr-login {
            margin-top: 20px;
            padding-top: 18px;
            border-top: 1px solid #d9d9d9;
            text-align: center;
        }

        .qr-panel {
            display: none;
            margin-top: 14px;
        }

        .qr-panel img {
            width: 220px;
            height: 220px;
            background: #fff;
            border: 1px solid #d9d9d9;
        }

        .qr-status {
            margin-top: 8px;
            color: rgba(0, 0, 0, 0.58);
            font-size: 13px;
            line-height: 1.5;
        }
    </style>
    <script src="https://nodestatic.fbstatic.cn/weblts_spa_online/page/assets/files/encrypt.js"></script>
</head>

<body style="background: #f5f7fa;">

<div>
    <form class="login-form">
        <input class="form-input" id="phone" type="text" placeholder="粉笔网手机号">
        <input class="form-input" id="password" type="password" placeholder="请输入密码">
        <div id="message" class="message" style="display: none;"></div>
        <div id="needauth" style="display: none;">
            <input class="form-input" id="authcode" type="text" name="captcha" placeholder="验证码">
        </div>
        <button id="login" type="submit" class="login-button">登录</button>
        <div class="qr-login">
            <button id="qrLogin" type="button" class="login-button">粉笔 App 扫码登录</button>
            <div id="qrPanel" class="qr-panel">
                <img id="qrImage" alt="粉笔扫码登录二维码">
                <div id="qrStatus" class="qr-status">请使用粉笔 App 扫码</div>
            </div>
        </div>
        <div class="cookie-login">
            <textarea id="cookieText" class="cookie-input" placeholder="从已登录的粉笔网页请求里复制 Cookie，粘贴到这里"></textarea>
            <button id="cookieLogin" type="button" class="login-button">使用 Cookie 登录</button>
        </div>
    </form>
</div>
</body>
<script>
    function setCookie(name, value, days) {
        var expires = "";
        if (days) {
            var date = new Date();
            date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
            expires = "; expires=" + date.toUTCString();
        }
        document.cookie = name + "=" + (value || "") + expires + "; path=/";
    }

    function getCookie(name) {
        var nameEQ = name + "=";
        var ca = document.cookie.split(';');
        for (var i = 0; i < ca.length; i++) {
            var c = ca[i];
            while (c.charAt(0) == ' ') c = c.substring(1, c.length);
            if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length, c.length);
        }
        return null;
    }

    function eraseCookie(name) {
        document.cookie = name + '=; Max-Age=-99999999;';
    }

    document.getElementById("login").addEventListener('click', function (event) {
        event.preventDefault();
        let password = document.getElementById("password").value;
        let publicKey = 'ANKi9PWuvDOsagwIVvrPx77mXNV0APmjySsYjB1/GtUTY6cyKNRl2RCTt608m9nYk5VeCG2EAZRQmQNQTyfZkw0Uo+MytAkjj17BXOpY4o6+BToi7rRKfTGl6J60/XBZcGSzN1XVZ80ElSjaGE8Ocg8wbPN18tbmsy761zN5SuIl';
        let message = document.getElementById('message');
        message.style.display = 'none';

        fetch(`/api/login/`, {
            method: 'POST',
            headers: {
                'content-type': 'application/json'
            },
            body: JSON.stringify({
                phone: document.getElementById("phone").value,
                password: window.encrypt(publicKey, password),
                captcha: document.getElementById("authcode").value
            })
        }).then(response => {
            if (response.status === 200) {
                return response.json();
            }
        }).then(result => {
            if (result.code !== 200) {
                document.getElementById('needauth').style.display = 'inline';
                message.innerText = result.message || '账号密码登录失败。粉笔旧图形验证码接口已经不可用，可以改用 Cookie 登录。';
                message.style.display = 'block';
            } else {
                window.location = result.redirectPath;
            }
        })
    })

    document.getElementById("cookieLogin").addEventListener('click', function (event) {
        event.preventDefault();
        let message = document.getElementById('message');
        message.style.display = 'none';
        fetch(`/api/useCookie`, {
            method: 'POST',
            headers: {
                'content-type': 'application/json'
            },
            body: JSON.stringify({
                cookieText: document.getElementById("cookieText").value
            })
        }).then(response => {
            if (response.status === 200) {
                return response.json();
            }
        }).then(result => {
            if (result.code === 200) {
                window.location = result.redirectPath;
            } else {
                message.innerText = result.message;
                message.style.display = 'block';
            }
        })
    })

    let qrTimer = null;

    function setQrStatus(text) {
        document.getElementById('qrStatus').innerText = text;
    }

    function pollQrLogin(lgtoken) {
        if (qrTimer) {
            clearTimeout(qrTimer);
        }
        fetch(`/api/qrcode/status`, {
            method: 'POST',
            headers: {
                'content-type': 'application/json'
            },
            body: JSON.stringify({
                lgtoken
            })
        }).then(response => response.json()).then(result => {
            if (result.hasUserId) {
                setQrStatus('登录成功，正在进入...');
                window.location = result.redirectPath;
                return;
            }
            if (result.data === 3 && !result.hasUserId) {
                setQrStatus('扫码已确认，但没有拿到题库登录态。请重新生成二维码再试。');
                return;
            }
            if (result.data === 2) {
                setQrStatus('已扫码，请在粉笔 App 中确认登录');
            } else if (result.data === 4) {
                setQrStatus('二维码已过期，请重新生成');
                return;
            } else if (result.data === 5) {
                setQrStatus(result.message || '登录失败，请重新生成二维码');
                return;
            } else {
                setQrStatus('请使用粉笔 App 扫码');
            }
            qrTimer = setTimeout(() => pollQrLogin(lgtoken), 2000);
        }).catch(() => {
            setQrStatus('查询登录状态失败，稍后重试');
            qrTimer = setTimeout(() => pollQrLogin(lgtoken), 2000);
        });
    }

    document.getElementById("qrLogin").addEventListener('click', function (event) {
        event.preventDefault();
        if (qrTimer) {
            clearTimeout(qrTimer);
        }
        setQrStatus('正在生成二维码...');
        document.getElementById('qrPanel').style.display = 'block';
        fetch(`/api/qrcode/start`, {
            method: 'POST'
        }).then(response => response.json()).then(result => {
            if (result.code === 200) {
                document.getElementById('qrImage').src = result.qrDataUrl;
                setQrStatus('请使用粉笔 App 扫码');
                pollQrLogin(result.lgtoken);
            } else {
                setQrStatus(result.message || '二维码生成失败');
            }
        }).catch(() => {
            setQrStatus('二维码生成失败，请检查网络');
        });
    })
</script>
</html>
